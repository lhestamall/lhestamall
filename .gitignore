# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# =============================================================================
# SECURITY-CRITICAL — never commit secrets, keys, or env-specific config
# =============================================================================
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets/
.secrets
*.secret
config.local.*
*.credentials

# =============================================================================
# Dependencies
# =============================================================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =============================================================================
# Build / output
# =============================================================================
/.next/
/out/
/build/
.turbo/
dist/

# =============================================================================
# Testing & coverage
# =============================================================================
/coverage
*.lcov
.nyc_output/

# =============================================================================
# Logs & debug
# =============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/

# =============================================================================
# IDE / editor (can contain local paths or env)
# =============================================================================
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# =============================================================================
# OS files
# =============================================================================
.DS_Store
Thumbs.db
ehthumbs.db

# =============================================================================
# Vercel / hosting
# =============================================================================
.vercel

# =============================================================================
# TypeScript / Next
# =============================================================================
*.tsbuildinfo
next-env.d.ts

# =============================================================================
# Data dumps / backups (may contain PII or secrets)
# =============================================================================
*.sql
*.dump
*.backup
*.bak

# =============================================================================
# Optional: docs / AI-generated (uncomment if you want these ignored)
# =============================================================================
CHECKLIST.md
README.md
EMAIL.md
FEATURES.md
DESIGN_SYSTEM.md
